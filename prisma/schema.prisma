generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Movie {
  id                Int          @id
  title             String
  overview          String
  posterPath        String
  releaseDate       DateTime
  voteAverage       Float
  runtime           Int?
  director          String?
  numberOfSeasons   Int?
  numberOfEpisodes  Int?
  mediaType         String       @default("movie")
  genres            Genre[]
  keywords          Keyword[]
  cast              CastMember[]
  ratings           Rating[]
  skips             Skip[]
  featureVector     String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Genre {
  id     Int     @id
  name   String
  movies Movie[]
}

model Keyword {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  movies Movie[]
}

model CastMember {
  id      Int     @id @default(autoincrement())
  name    String
  role    String
  tmdbId  Int
  order   Int
  movieId Int
  movie   Movie   @relation(fields: [movieId], references: [id])
}

model Rating {
  id        Int      @id @default(autoincrement())
  movieId   Int
  value     Int
  movie     Movie    @relation(fields: [movieId], references: [id])
  createdAt DateTime @default(now())

  @@unique([movieId])
}

model Skip {
  id        Int      @id @default(autoincrement())
  movieId   Int      @unique
  movie     Movie    @relation(fields: [movieId], references: [id])
  createdAt DateTime @default(now())
}
